{% extends 'base.html.twig' %}

{% block title %}Panier{% endblock %}

{% block body %}
    <section class="cart-area section-padding">
        <div class="container">
            <h2 class="text-center fw-bold mb-4">🛒 Votre Panier</h2>

            {# Cart Table Container #}
            <div class="card shadow-lg rounded-lg p-4">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead class="table-dark text-white">
                        <tr>
                            <th scope="col">Image</th>
                            <th scope="col">Nom</th>
                            <th scope="col">Prix</th>
                            <th scope="col" class="text-center">Quantité</th>
                            <th scope="col">Total</th>
                            <th scope="col" class="text-center">Action</th>
                        </tr>
                        </thead>
                        <tbody id="cart-items">
                        </tbody>
                    </table>
                </div>

                {# Empty Cart Message #}
                <p id="empty-cart" class="text-center text-muted mt-3 d-none">🛍️ Votre panier est vide.</p>

                {# Cart Actions #}
                <div class="d-flex justify-content-between mt-4">
                    <button id="clear-cart" class="btn btn-danger px-4 py-2 shadow-sm">
                        🗑️ Vider le Panier
                    </button>
                    <button id="checkout" class="btn btn-success px-4 py-2 shadow-sm">
                        ✅ Commander
                    </button>
                </div>
            </div>
        </div>
    </section>

    {# Include jQuery #}
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        $(document).ready(function () {
            let cart = JSON.parse(localStorage.getItem("cart")) || [];

            function renderCart() {
                let cartTable = $("#cart-items");
                cartTable.html("");

                if (cart.length === 0) {
                    $("#empty-cart").removeClass("d-none");
                    return;
                } else {
                    $("#empty-cart").addClass("d-none");
                }

                cart.forEach((item, index) => {
                    let row = `
                <tr class="border-bottom">
                    <td>
                        <img src="${item.image}" class="rounded shadow-sm" style="width: 60px; height: 60px; object-fit: cover;">
                    </td>
                    <td class="fw-semibold">${item.name}</td>
                    <td class="text-primary fw-bold">${item.price} €</td>
                    <td class="text-center">
                        <button class="btn btn-light btn-sm change-qty" data-index="${index}" data-action="decrease">➖</button>
                        <span class="mx-2 fw-semibold">${item.quantity}</span>
                        <button class="btn btn-light btn-sm change-qty" data-index="${index}" data-action="increase">➕</button>
                    </td>
                    <td class="fw-bold">${(item.price * item.quantity).toFixed(2)} €</td>
                    <td class="text-center">
                        <button class="btn btn-sm btn-outline-danger remove-item" data-index="${index}">❌</button>
                    </td>
                </tr>
            `;
                    cartTable.append(row);
                });
            }

            $(document).on("click", ".change-qty", function () {
                let index = $(this).data("index");
                let action = $(this).data("action");

                if (action === "increase") {
                    cart[index].quantity += 1;
                } else if (action === "decrease" && cart[index].quantity > 1) {
                    cart[index].quantity -= 1;
                }

                localStorage.setItem("cart", JSON.stringify(cart));
                renderCart();
            });

            $(document).on("click", ".remove-item", function () {
                let index = $(this).data("index");
                cart.splice(index, 1);
                localStorage.setItem("cart", JSON.stringify(cart));
                renderCart();
            });

            $("#clear-cart").click(function () {
                localStorage.removeItem("cart");
                cart = [];
                renderCart();
            });

            $("#checkout").click(function () {
                $.ajax({
                    url: "{{ path('app_panier_checkout') }}",
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify(cart),
                    success: function (response) {
                        localStorage.removeItem("cart"); // Clear cart
                        window.location.href = response.url; // Redirect to Stripe checkout
                    },
                    error: function () {
                        alert("⚠️ Une erreur est survenue lors du paiement.");
                    }
                });
            });

            renderCart();
        });
    </script>


{% endblock %}
