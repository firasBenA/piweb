{% extends 'base.html.twig' %}

{% block title %}Create new Produit{% endblock %}

{% block body %}
<div style="background-color: #72c1ec; padding: 30px 0;">
    <div class="container" style="max-width: 800px;">
        <h1 class="text-white text-center mb-4">Créer un Produit</h1>

        <div class="card border-0 shadow">
            <div class="card-body p-4" style="background-color: #aee1f8;">
                {{ form_start(form, {
                    'attr': {
                        'novalidate': 'novalidate',
                        'enctype': 'multipart/form-data'
                    }
                }) }}

                    <div class="row mb-3">
                        <div class="col-md-6">
                            {{ form_label(form.nom, 'Nom du produit', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.nom, {
                                'attr': {
                                    'class': 'form-control',
                                    'placeholder': 'Ex: Doliprane, Ibuprofène...'
                                }
                            }) }}
                            {{ form_errors(form.nom) }}
                        </div>

                        <div class="col-md-6">
                            {{ form_label(form.prix, 'Prix (DTN)', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.prix, {
                                'attr': {
                                    'class': 'form-control',
                                    'step': '0.01',
                                    'placeholder': 'Ex: 10.00'
                                }
                            }) }}
                            {{ form_errors(form.prix) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                        {{ form_widget(form.description, {
                            'attr': {
                                'class': 'form-control',
                                'rows': 3,
                                'placeholder': 'Ex: Médicament pour...'
                            }
                        }) }}
                        {{ form_errors(form.description) }}
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            {{ form_label(form.stock, 'Stock disponible', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.stock, {
                                'attr': {
                                    'class': 'form-control',
                                    'min': '0'
                                }
                            }) }}
                            {{ form_errors(form.stock) }}
                        </div>

                        <div class="col-md-6">
                            {{ form_label(form.image, 'Image (JPEG ou PNG)', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.image, {
                                'attr': {
                                    'class': 'form-control'
                                }
                            }) }}
                            {{ form_errors(form.image) }}
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <a href="{{ path('app_produit_index') }}" class="btn btn-outline-secondary">
                            Back to list
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2-circle"></i> Save
                        </button>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
